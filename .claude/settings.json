{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "command": "code-review-graph update --skip-flows",
        "timeout": 5000
      }
    ],
    "SessionStart": [
      {
        "command": "code-review-graph status",
        "timeout": 3000
      }
    ],
    "PreCommit": [
      {
        "command": "code-review-graph detect-changes --brief",
        "timeout": 10000
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx tsc *)",
      "Read(//c/Users/kyath/.claude/projects/c--Users-kyath-Desktop-Zero-To-Stack/memory/**)"
    ],
    "additionalDirectories": [
      "c:\\Users\\kyath\\.claude\\projects\\c--Users-kyath-Desktop-Zero-To-Stack\\memory"
    ]
  }
}
