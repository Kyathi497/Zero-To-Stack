# Neon pooled connection (used by Prisma at runtime via connection pooler)
DATABASE_URL="postgresql://<user>:<password>@<project-id>-pooler.neon.tech/<dbname>?sslmode=require"

# Neon direct connection (used by Prisma Migrate / db push)
DIRECT_DATABASE_URL="postgresql://<user>:<password>@<project-id>.neon.tech/<dbname>?sslmode=require"

JWT_SECRET="your-super-secret-jwt-key-change-in-production"
